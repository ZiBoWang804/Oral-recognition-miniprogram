<view class="tab-bar">
  <view 
    wx:for="{{currentTabs}}"
    wx:key="index"
    class="tab-bar-item {{selected === index ? 'active' : ''}}"
    bindtap="switchTab"
    data-index="{{index}}"
    data-path="{{item.pagePath}}"
  >
    <image class="tab-bar-icon" src="{{selected === index ? item.selectedIconPath : item.iconPath}}"></image>
    <text class="tab-bar-text">{{item.text}}</text>
  </view>
</view>