.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 150rpx;
  display: flex;
  background: #fff;
  border-top: 1rpx solid #e5e5e5;
  z-index: 999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tab-bar-icon {
  width: 48rpx;
  height: 48rpx;
  margin-top: 8rpx;
}

.tab-bar-text {
  font-size: 20rpx;
  margin-top: 4rpx;
  color: #7A7E83;
}

.tab-bar-item.active .tab-bar-text {
  color: #07C160;
}