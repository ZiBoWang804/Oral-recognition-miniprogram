.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 150 rpx;
  padding-bottom: env(safe-area-inset-bottom);
  display: flex;
  background: #fff;
  border-top: 1rpx solid #e5e5e5;
  z-index: 9999;
  box-shadow: 0 -2rpx 6rpx rgba(0, 0, 0, 0.05);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.tab-bar-item::after {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background-color: #000;
  opacity: 0;
  transition: opacity 0.2s;
}

.tab-bar-item:active::after {
  opacity: 0.1;
}

.tab-bar-icon {
  width: 48rpx;
  height: 48rpx;
  margin-top: 6rpx;
}

.tab-bar-text {
  font-size: 24rpx;
  margin-top: 4rpx;
  color: #7A7E83;
}

.tab-bar-item.active .tab-bar-text {
  color: #07C160;
  font-weight: 500;
}