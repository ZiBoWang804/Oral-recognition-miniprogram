
/* 微信原生风格样式 */
page {
  background-color: #F7F7F7;
}

/* 悬浮添加按钮样式 */
.float-btn {
  position: fixed;
  right: 30rpx;
  bottom: 160rpx;
  width: auto;
  height: 80rpx;
  border-radius: 10rpx;
  background-color: #07C160;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0 24rpx;
  z-index: 999;
}

.float-btn image {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
}

.float-btn text {
  color: #FFFFFF;
  font-size: 28rpx;
  white-space: nowrap;
}

.float-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

/* 原有样式保持不变 */
.addview {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.addtext {
  font-size: 28rpx;
}

.container {
  position: relative;
  height: 100%;
}

.scan {
  font-size: 28rpx;
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  background-color: #07C160;
  border-radius: 30rpx;
  padding: 10rpx 20rpx;
  color: white;
}

.child_list {
  padding: 16rpx;
}

/* 儿童卡片样式 - 优化版 */
.child_card {
  background-color: #FFFFFF;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  padding: 24rpx;
  padding-top: 40rpx; /* 减少顶部内边距 */
  display: flex;
  align-items: flex-start; /* 改为顶部对齐 */
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
}

/* 二维码按钮样式 - 修改后 */
.qr-btn {
  display: block;
  width: 100%;
  margin: 0;
  font-size: 24rpx;
  line-height: 1.5;
  padding: 8rpx 16rpx;
  background-color: #07C160;
  color: white;
  border-radius: 6rpx;
  z-index: 2;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.1);
  text-align: center;
}

.qr-btn::after {
  border: none;
}

.qr-btn:active {
  opacity: 0.8;
  transform: scale(0.95); /* 添加点击动画 */
}

/* 调整箭头位置避免重叠 */
.card_arrow {
  top: 60rpx; /* 下移箭头位置 */
}

/* 儿童照片 - 矩形样式 */
.child_photo_rect {
  width: 180rpx;
  height: 220rpx;
  margin-right: 24rpx;
  border-radius: 6rpx;
  object-fit: cover;
}

/* 信息容器 */
.card_info_container {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  margin-right: 60rpx; /* 给箭头留出空间 */
}

/* 信息文字样式 */
.card_info {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
  margin: 4rpx 0;
}

/* 突出显示姓名 */
.card_info:first-child {
  font-weight: 500;
  color: #222;
}

/* 卡片点击效果 */
.child_card:active {
  transform: scale(0.98);
  opacity: 0.8;
}

/* 右侧箭头 */
.card_arrow {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #CCCCCC;
  font-size: 32rpx;
}

.empty-tip {
  text-align: center;
  color: #999999;
  font-size: 28rpx;
  margin-top: 200rpx;
}

.picker {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #E8E8EA;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  position: relative;
}

.picker::after {
  content: '';
  display: block;
  width: 12rpx;
  height: 12rpx;
  border-right: 2rpx solid #999;
  border-bottom: 2rpx solid #999;
  position: absolute;
  right: 20rpx;
  transform: rotate(45deg);
}

.image_view {
  margin-top: 16rpx;
}

.image {
  width: 100%;
  height: auto;
  border-radius: 4rpx;
}

.update {
  position: fixed;
  bottom: 32rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80%;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #07C160;
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
  text-align: center;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-content {
  width: 80%;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 140rpx;
}

.modal-header {
  padding: 28rpx 32rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
  line-height: 1.4;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 0;
}

.modal-body-content {
  padding: 30rpx;
  min-height: 100%;
  box-sizing: border-box;
}

/* 设置滚动条样式 */
::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}

/* 照片选择/预览区域样式 */
.photo-section {
  width: 100%;
  height: 300rpx;
  margin-bottom: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.photo-placeholder {
  width: 100%;
  height: 100%;
  background-color: #F7F7F7;
  border: 2rpx dashed #CCCCCC;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  cursor: pointer;
}

.photo-placeholder text {
  font-size: 28rpx;
  color: #999999;
  margin-top: 20rpx;
}

.add-photo-icon {
  width: 80rpx;
  height: 80rpx;
  opacity: 0.5;
}

.photo-preview {
  width: 100%;
  height: 100%;
  position: relative;
}

.photo-preview image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  object-fit: cover;
}

.input-group {
  margin-bottom: 24rpx;
}

.input-group text {
  display: block;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  color: #333333;
}

.input-group input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #E8E8EA;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input-group radio-group {
  display: flex;
  gap: 30rpx;
}

.input-group radio {
  font-size: 28rpx;
  color: #333333;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #E8E8EA;
  background: #FFFFFF;
  justify-content: space-between;
  flex-shrink: 0;
}

.modal-footer button {
  width: 45%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 8rpx;
  text-align: center;
}

.btn-cancel {
  background-color: #F7F7F7;
  color: #666666;
}

.btn-confirm {
  background-color: #07C160;
  color: #FFFFFF;
}

.modal-footer button:active {
  opacity: 0.8;
}
