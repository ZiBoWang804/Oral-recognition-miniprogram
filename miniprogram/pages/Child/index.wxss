.container {
  height: 100vh;
  background-color: #f7f7f7;
  position: relative;
}

/* 儿童卡片 */
.child-card {
  background: #fff;
  border-radius: 12rpx;
  margin: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.child-info {
  padding: 25rpx;
  display: flex;
  align-items: center;
}

.child-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.child-details {
  flex: 1;
}

.child-name {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.child-meta {
  font-size: 26rpx;
  color: #999;
}

/* 二维码按钮 */
.qrcode-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #f0f0f0;
  border-radius: 0;
  border-top: 1rpx solid #eee;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  color: #666;
}

.qrcode-btn image {
  width: 36rpx;
  height: 36rpx;
  margin-right: 10rpx;
}

/* 悬浮按钮 */
.floating-btn {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx; /* 上移后的位置 */
  width: 220rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #07C160, #09AF55);
  box-shadow: 0 8rpx 20rpx rgba(7,193,96,0.3);
  display: flex;
  justify-content: center;
  align-items: center;
  color: white;
  font-size: 28rpx;
  z-index: 100; /* 确保在列表上方 */
}

.floating-btn image {
  width: 36rpx;
  height: 36rpx;
  margin-right: 10rpx;
}

.floating-btn text {
  color: #fff;
  font-size: 28rpx;
}

/* 二维码弹窗 */
.qrcode-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.modal-content {
  background: #fff;
  width: 80%;
  padding: 40rpx;
  border-radius: 16rpx;
  text-align: center;
}

.qrcode-image {
  width: 400rpx;
  height: 400rpx;
  margin-bottom: 30rpx;
}

.qrcode-id {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 30rpx;
}

.close-btn {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #07C160;
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
}