<!--pages/sign-in/index.wxml-->
<view class="page">
  <view class="page-section">
    <view class="weui-cells__title">基本信息</view>
    <view class="weui-cells weui-cells_after-title">
      <!-- 姓名输入框 -->
      <view class="weui-cell weui-cell_input">
        <view class="weui-cell__hd">
          <view class="weui-label">姓名</view>
        </view>
        <view class="weui-cell__bd">
          <input class="weui-input" placeholder="请输入姓名" bindinput="onNameInput"/>
        </view>
      </view>
      
      <!-- 年龄输入框 -->
      <view class="weui-cell weui-cell_input">
        <view class="weui-cell__hd">
          <view class="weui-label">年龄</view>
        </view>
        <view class="weui-cell__bd">
          <input class="weui-input" type="number" placeholder="请输入年龄" bindinput="onAgeInput"/>
        </view>
      </view>
      
      <!-- 性别选择器 -->
      <view class="weui-cell weui-cell_select">
        <view class="weui-cell__hd">
          <view class="weui-label">性别</view>
        </view>
        <view class="weui-cell__bd">
          <picker mode="selector" value="{{gendersindex}}" range="{{genders}}" bindchange="onGenderChange">
            <view class="weui-select">{{selectgender || '请选择性别'}}</view>
          </picker>
        </view>
      </view>

      <!-- 籍贯选择器 -->
      <view class="weui-cell weui-cell_select">
        <view class="weui-cell__hd">
          <view class="weui-label">籍贯</view>
        </view>
        <view class="weui-cell__bd">
          <picker mode="region" value="{{regionindex}}" bindchange="onRegionChange">
            <view class="weui-select"> {{ selectregion}} </view>
          </picker>
        </view>
      </view>

      <!-- 住址输入框 -->
      <view class="weui-cell weui-cell_input">
        <view class="weui-cell__hd">
          <view class="weui-label">住址</view>
        </view>
        <view class="weui-cell__bd">
          <input class="weui-input" type="number" placeholder="请输入住址" bindinput="onHomeInput"/>
        </view>
      </view>

      <!-- 收入输入框 -->
      <view class="weui-cell weui-cell_input">
        <view class="weui-cell__hd">
          <view class="weui-label">收入</view>
        </view>
        <view class="weui-cell__bd">
          <input class="weui-input" type="number" placeholder="请输入月收入" bindinput="onInInput"/>
        </view>
      </view>

      <!-- 学历选择器 -->
      <view class="weui-cell weui-cell_select">
        <view class="weui-cell__hd">
          <view class="weui-label">学历</view>
        </view>
        <view class="weui-cell__bd">
          <picker mode="selector" value="{{edbcindex}}" range="{{edbc}}" bindchange="onEdbcChange">
            <view class="weui-select">{{selectedbc || '请选择学历'}}</view>
          </picker>
        </view>
      </view>
      
      <!-- 手机号绑定 -->
      <view class="weui-cell weui-cell_input">
        <view class="weui-cell__hd">
          <view class="weui-label">手机号</view>
        </view>
        <view class="weui-cell__bd">
          <view class="phone-section">
            <text class="phone-text">{{setphoneNumber}}</text>
            <view class="btn-wrapper">
              <button class="weui-btn mini-btn" type="primary" size="mini"
                      open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
                {{phone ? '更换' : '获取手机号'}}
              </button>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="weui-btn-area">
    <button class="weui-btn" type="primary" bindtap="onSubmit">完成注册</button>
  </view>

  <!-- 底部提示 -->
  <view class="page-footer">
    <text class="footer-text">注册即代表同意《用户协议》和《隐私政策》</text>
  </view>
</view>