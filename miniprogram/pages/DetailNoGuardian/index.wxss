
/* pages/DetailNoGuardian/index.wxss - 微信原生风格 */
page {
  background-color: #f7f7f7;
  padding: 20rpx;
}

.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.card-title::before {
  content: "";
  display: inline-block;
  width: 8rpx;
  height: 32rpx;
  background-color: #07C160;
  margin-right: 16rpx;
  border-radius: 4rpx;
}

.info-row {
  display: flex;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.info-label {
  color: #999;
  width: 200rpx;
  margin-right: 20rpx;
}

.info-value {
  color: #333;
  flex: 1;
}

.divider {
  height: 1rpx;
  background-color: #eee;
  margin: 30rpx 0;
}

.image-container {
  display: flex;
  justify-content: center;
  margin: 30rpx 0;
}

.tooth-image {
  width: 100%;
  max-width: 800rpx;
  height: 450rpx;
  border-radius: 8rpx;
}

.tooth-image-full {
  width: 100%;
  height: 400rpx;
  border-radius: 8rpx;
}

/* 底部按钮容器样式 - 新增 */
.footer-button-container {
  padding: 40rpx 20rpx;
  margin-top: 20rpx;
}

/* 主要按钮样式 - 调整为微信原生风格 */
.primary-button {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #07C160;
  color: white;
  border-radius: 16rpx;
  font-size: 32rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.1);
  box-sizing: border-box;
  transition: all 0.1s;
}

/* 按钮点击效果 - 调整为微信原生风格 */
.primary-button:active {
  background-color: #06AD56;
  transform: scale(0.98);
}

/* 二维码按钮样式 - 从Child页面迁移 */
.qr-btn {
  display: block;
  width: calc(100% - 40rpx);
  margin: 0 auto 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  padding: 16rpx;
  background-color: #07C160;
  color: white;
  border-radius: 8rpx;
  text-align: center;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.1);
}

.qr-btn::after {
  border: none;
}

.qr-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 二维码模态框样式 - 优化版 */
.qr-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.qr-modal.show {
  opacity: 1;
}

.qr-container {
  background-color: #fff;
  padding: 40rpx;
  border-radius: 16rpx;
  text-align: center;
  width: 600rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transform: scale(0.9);
  transform-origin: center;
  transition: transform 0.3s ease;
}

.qr-modal.show .qr-container {
  transform: scale(1);
}

.qr-image {
  width: 500rpx;
  height: 500rpx;
  margin-bottom: 30rpx;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.qr-tip {
  color: #666;
  font-size: 28rpx;
  margin-top: 20rpx;
  line-height: 1.5;
}

/* 防止点击穿透 */
.stop-propagation {
  pointer-events: none;
}

/* 展示检查码按钮容器 */
.btn-container {
  padding: 30rpx 20rpx;
  margin: 20rpx 0;
  display: flex;
  justify-content: center;
}

/* 展示检查码按钮 - 优化交互 */
.show-code-btn {
  width: 100%;
  min-height: 88rpx;
  line-height: 88rpx;
  background-color: #07C160;
  color: white;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 8rpx rgba(7, 193, 96, 0.2);
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.show-code-btn::after {
  border: none;
}

.show-code-btn:not([disabled]):active {
  background-color: #06AD56;
  transform: scale(0.98);
  box-shadow: 0 2rpx 4rpx rgba(7, 193, 96, 0.1);
}