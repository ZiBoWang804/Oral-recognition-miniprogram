<!--pages/sign-in/index.wxml-->
<view class="page">
  <view class="page-section">
    <view class="weui-cells__title">基本信息</view>
    <view class="weui-cells weui-cells_after-title">
      <!-- 姓名输入框 -->
      <view class="weui-cell weui-cell_input">
        <view class="weui-cell__hd">
          <view class="weui-label">姓名</view>
        </view>
        <view class="weui-cell__bd">
          <input class="weui-input" placeholder="请输入姓名" bindinput="onNameInput"/>
        </view>
      </view>
      
      <!-- 年龄输入框 -->
      <view class="weui-cell weui-cell_input">
        <view class="weui-cell__hd">
          <view class="weui-label">年龄</view>
        </view>
        <view class="weui-cell__bd">
          <input class="weui-input" type="number" placeholder="请输入年龄" bindinput="onAgeInput"/>
        </view>
      </view>
      
      <!-- 性别选择器 -->
      <view class="weui-cell weui-cell_select">
        <view class="weui-cell__hd">
          <view class="weui-label">性别</view>
        </view>
        <view class="weui-cell__bd">
          <picker mode="selector" range="{{genders}}" bindchange="onGenderChange">
            <view class="weui-select">{{gender || '请选择性别'}}</view>
          </picker>
        </view>
      </view>
      
      <!-- 手机号绑定 -->
      <view class="weui-cell weui-cell_input">
        <view class="weui-cell__hd">
          <view class="weui-label">手机号</view>
        </view>
        <view class="weui-cell__bd">
          <view class="phone-section">
            <text class="phone-text">{{phone || '未绑定'}}</text>
            <button class="weui-btn mini-btn" type="primary" size="mini"
                    open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
              {{phone ? '更换' : '获取手机号'}}
            </button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="weui-btn-area">
    <button class="weui-btn" type="primary" bindtap="onSubmit">完成注册</button>
  </view>

  <!-- 底部提示 -->
  <view class="page-footer">
    <text class="footer-text">注册即代表同意</text>
    <navigator url="/pages/agreement/index" class="footer-link">《用户协议》</navigator>
    <text class="footer-text">和</text>
    <navigator url="/pages/privacy/index" class="footer-link">《隐私政策》</navigator>
  </view>
</view>