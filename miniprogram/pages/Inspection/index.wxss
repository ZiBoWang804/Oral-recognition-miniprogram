
.container {
  padding: 15px;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.form-section {
  margin-bottom: 20px;
}

.form-item {
  display: flex;
  align-items: center;
  margin-bottom: 15px;
}

.form-label {
  width: 120px;
  font-size: 16px;
}

.form-input {
  flex: 1;
  border: 1px solid #ddd;
  border-radius: 4px;
  padding: 8px 10px;
  font-size: 14px;
}

.image-section {
  margin-bottom: 20px;
  border: 1px dashed #ddd;
  border-radius: 4px;
}

.preview-image {
  width: 100%;
  height: 200px;
  background-color: #f5f5f5;
}

.button-section {
  display: flex;
  justify-content: space-between;
  margin-top: 20px;
  margin-bottom: 20px;
}

.camera-btn {
  width: 48%;
  font-size: 14px;
}

.submit-btn {
  width: 48%;
}