
/* pages/Detail/index.wxss - 微信原生风格 */
page {
  background-color: #f7f7f7;
  padding: 20rpx;
}

.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.card-title::before {
  content: "";
  display: inline-block;
  width: 8rpx;
  height: 32rpx;
  background-color: #07C160;
  margin-right: 16rpx;
  border-radius: 4rpx;
}

.info-row {
  display: flex;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.info-label {
  color: #999;
  width: 200rpx;
}

.info-value {
  color: #333;
  flex: 1;
}

.divider {
  height: 1rpx;
  background-color: #eee;
  margin: 30rpx 0;
}

.image-container {
  display: flex;
  justify-content: center;
  margin: 30rpx 0;
}

.tooth-image {
  width: 100%;
  max-width: 500rpx;
  height: auto;
  border-radius: 8rpx;
}

.tooth-image-full {
  width: 100%;
  height: 400rpx;
  border-radius: 8rpx;
}

/* 底部按钮容器样式 - 新增 */
.footer-button-container {
  padding: 40rpx 20rpx;
  margin-top: 20rpx;
}

/* 主要按钮样式 - 调整为微信原生风格 */
.primary-button {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #07C160;
  color: white;
  border-radius: 16rpx;
  font-size: 32rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.1);
  box-sizing: border-box;
  transition: all 0.1s;
}

/* 按钮点击效果 - 调整为微信原生风格 */
.primary-button:active {
  background-color: #06AD56;
  transform: scale(0.98);
}