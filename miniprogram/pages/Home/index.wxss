/* pages/home/index.wxss */
.page {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background-color: #ffffff;
}

.logo-container {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  margin-bottom: 40rpx;
  transform: translateY(-80rpx);
}

.logo {
  width: 95%;
  max-width: 800rpx;
  height: 600rpx;
}

.weui-btn_primary {
  width: 85%;
  position: absolute;
  bottom: 160rpx;
  height: 94rpx;
  font-size: 36rpx;
  font-weight: 500;
  border-radius: 10rpx;
  background-color: #07C160;
}

.weui-btn_primary.button-hover {
  background-color: #06AD56;
}

.loading {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.8);
}

.loading-text {
  color: #07C160;
  font-size: 28rpx;
}

.loading-dots::after {
  content: '...';
  animation: dot-animation 1.5s infinite;
}

@keyframes dot-animation {
  0% { opacity: 1; }
  50% { opacity: 0.5; }
  100% { opacity: 1; }
}